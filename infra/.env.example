# ============================================================
# Smart Music Streaming Platform — Local Development
# ============================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to git — it is listed in .gitignore
# ============================================================


# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_USER=smartmusic
POSTGRES_PASSWORD=changeme_local
POSTGRES_DB=smartmusic

# Per-service connection strings (each service gets its own DB)
AUTH_DB_CONNECTION=Host=postgres;Port=5432;Database=auth_db;Username=smartmusic;Password=changeme_local
USER_DB_CONNECTION=Host=postgres;Port=5432;Database=user_db;Username=smartmusic;Password=changeme_local
MUSIC_DB_CONNECTION=Host=postgres;Port=5432;Database=music_db;Username=smartmusic;Password=changeme_local
STREAMING_DB_CONNECTION=Host=postgres;Port=5432;Database=streaming_db;Username=smartmusic;Password=changeme_local
LISTENING_PARTY_DB_CONNECTION=Host=postgres;Port=5432;Database=listening_party_db;Username=smartmusic;Password=changeme_local
ANALYTICS_DB_CONNECTION=Host=postgres;Port=5432;Database=analytics_db;Username=smartmusic;Password=changeme_local
NOTIFICATION_DB_CONNECTION=Host=postgres;Port=5432;Database=notification_db;Username=smartmusic;Password=changeme_local


# ============================================================
# Redis
# ============================================================
REDIS_PASSWORD=changeme_local
# For .NET services (StackExchange.Redis format)
REDIS_CONNECTION=redis:6379,password=changeme_local
# For Python services
REDIS_URL=redis://:changeme_local@redis:6379


# ============================================================
# MongoDB
# ============================================================
MONGO_USERNAME=admin
MONGO_PASSWORD=changeme_local
MONGO_URI=mongodb://admin:changeme_local@mongodb:27017


# ============================================================
# Kafka
# ============================================================
# Use internal docker network address for service-to-service
KAFKA_BOOTSTRAP_SERVERS=kafka:29092


# ============================================================
# InfluxDB
# ============================================================
INFLUXDB_ADMIN_USERNAME=admin
INFLUXDB_ADMIN_PASSWORD=changeme_local
INFLUXDB_TOKEN=my-super-secret-token-change-this-in-production
INFLUXDB_ORG=smartmusic
INFLUXDB_BUCKET=analytics


# ============================================================
# JWT
# ============================================================
# Must be at least 32 characters (256-bit) for HS256
JWT_SECRET=your-256-bit-secret-key-here-minimum-32-characters-change-me
JWT_ACCESS_TOKEN_EXPIRY=3600
JWT_REFRESH_TOKEN_EXPIRY=604800


# ============================================================
# AWS S3 / MinIO (local dev uses MinIO)
# ============================================================
# For local development these point at the MinIO container
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=smartmusic-audio
# Override the endpoint so the SDK hits MinIO instead of real AWS
AWS_S3_ENDPOINT=http://minio:9000
AWS_REGION=us-east-1


# ============================================================
# Elasticsearch
# ============================================================
ELASTICSEARCH_URL=http://elasticsearch:9200


# ============================================================
# Internal service URLs (docker network)
# ============================================================
AUTH_SERVICE_URL=http://auth-service:80
USER_SERVICE_URL=http://user-service:80
MUSIC_SERVICE_URL=http://music-service:80
STREAMING_SERVICE_URL=http://streaming-service:80
LISTENING_PARTY_SERVICE_URL=http://listening-party-service:80
ANALYTICS_SERVICE_URL=http://analytics-service:80
NOTIFICATION_SERVICE_URL=http://notification-service:80
SEARCH_SERVICE_URL=http://search-service:80
RECOMMENDATION_SERVICE_URL=http://recommendation-service:8000

# ==========================================
# GOOGLE CLOUD STORAGE (Lưu trữ file nhạc .mp3)
# ==========================================
GCP_PROJECT_ID="nhap-project-id-cua-ban-vao-day"
GCP_BUCKET_NAME="nhap-ten-bucket-cua-ban"

# Biến này RẤT QUAN TRỌNG. Google Cloud SDK sẽ tự động tìm kiếm tên biến này.
# Giá trị là đường dẫn tới file .json (Service Account Key) bạn đã tải về ở Bước 3.
GOOGLE_APPLICATION_CREDENTIALS="./secrets/google-cloud-key.json"


# ==========================================
# CLOUDINARY (Lưu trữ Avatar, Ảnh bìa Album/Playlist)
# ==========================================
CLOUDINARY_CLOUD_NAME="nhap-cloud-name"
CLOUDINARY_API_KEY="nhap-api-key"
CLOUDINARY_API_SECRET="nhap-api-secret"
CLOUDINARY_SECURE=true

# (Hoặc Cloudinary đôi khi cung cấp 1 URL duy nhất bao gồm cả 3 thông số trên)
# CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"