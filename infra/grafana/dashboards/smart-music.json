{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "API Latency p95 by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}} p95",
          "refId": "A"
        }
      ],
      "description": "p95 latency per service. Alert if > 500ms sustained 5 min."
    },
    {
      "id": 2,
      "title": "Streaming Start Time p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"streaming-service\"}[5m])))",
          "legendFormat": "streaming p95",
          "refId": "A"
        }
      ],
      "description": "Time to first byte for streaming requests. Target < 1s."
    },
    {
      "id": 3,
      "title": "Kafka Consumer Lag",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "kafka_consumer_group_lag{consumer_group=~\"analytics-service|recommendation-service|notification-service\"}",
          "legendFormat": "{{consumer_group}} / {{topic}}",
          "refId": "A"
        }
      ],
      "description": "Kafka lag per consumer group. Alert if lag > 10 for analytics or recommendation."
    },
    {
      "id": 4,
      "title": "Recommendation CTR",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "green", "value": 0.10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"streaming-service\", handler=\"/api/v1/streaming/{songId}/url\"}[1h]) / clamp_min(rate(http_requests_total{job=\"recommendation-service\", handler=\"/api/v1/recommendations\"}[1h]), 0.001)",
          "legendFormat": "CTR",
          "refId": "A"
        }
      ],
      "description": "Click-through rate: streaming requests / recommendation requests. Target > 10%."
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["smart-music", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Smart Music Platform",
  "uid": "smart-music-v1",
  "version": 1
}
